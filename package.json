{
  "name": "basenative",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:static": "npx serve examples/static",
    "dev:express": "node examples/express/server.js",
    "serve": "node examples/express/server.js",
    "bundle": "esbuild src/runtime/index.js --bundle --format=esm --outfile=examples/express/public/basenative.js",
    "test": "node --test src/**/*.test.js",
    "lint": "node --check src/**/*.js examples/express/server.js",
    "postinstall": "npx -y skills add nrwl/nx-ai-agents-config -y"
  },
  "dependencies": {
    "express": "^5.1.0",
    "node-html-parser": "^7.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "nx": "^20.3.2",
    "nx-mcp": "^0.23.0"
  },
  "exports": {
    ".": "./src/runtime/index.js",
    "./server": "./src/server/render.js"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "nx"
    ]
  }
}
