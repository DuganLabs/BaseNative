{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "BaseNative / DuganLabs default Claude Code settings. Generated by @basenative/claude-config. Edit settings.local.json for personal overrides.",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(pnpm install)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm dev:*)",
      "Bash(node --test:*)",
      "Bash(npx nx:*)",
      "Bash(wrangler whoami)",
      "Bash(wrangler deployments list:*)",
      "Bash(wrangler d1 migrations list:*)",
      "Bash(wrangler kv namespace list:*)",
      "Bash(wrangler r2 bucket list:*)",
      "Bash(wrangler secret list:*)",
      "Bash(doppler me)",
      "Bash(doppler projects:*)",
      "Bash(doppler configs:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue view:*)",
      "Bash(bn doctor)",
      "Bash(bn-claude verify)",
      "Bash(bn-claude list)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(pnpm publish:*)",
      "Bash(npm publish:*)",
      "Bash(wrangler deploy:*)",
      "Bash(wrangler pages deploy:*)",
      "Bash(wrangler d1 execute:*)",
      "Bash(wrangler secret put:*)",
      "Bash(wrangler secret delete:*)",
      "Bash(wrangler kv key put:*)",
      "Bash(wrangler kv key delete:*)",
      "Bash(wrangler r2 object put:*)",
      "Bash(wrangler r2 object delete:*)",
      "Bash(doppler secrets upload:*)",
      "Bash(doppler secrets delete:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh release create:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-bash-deploy-confirm.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-tool-edit-format.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-secret-scan.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "BASENATIVE_PROJECT": "true"
  }
}
