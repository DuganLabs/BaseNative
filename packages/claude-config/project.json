{
  "name": "@basenative/claude-config",
  "targets": {
    "test": {
      "cache": true,
      "command": "node --test",
      "inputs": ["{projectRoot}/src/**/*.js", "{projectRoot}/test/**/*.js"]
    },
    "lint": {
      "cache": true,
      "command": "pnpm exec eslint src",
      "options": { "cwd": "{projectRoot}" },
      "inputs": ["{projectRoot}/src/**/*.js", "{projectRoot}/bin/**/*.js"]
    }
  }
}
