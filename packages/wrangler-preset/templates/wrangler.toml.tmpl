# ──────────────────────────────────────────────────────────────────────────
#   wrangler.toml — generated from @basenative/wrangler-preset
#   Edit the placeholders below, then run: bn-wrangler deploy
# ──────────────────────────────────────────────────────────────────────────

name = "__PROJECT_NAME__"
main = "src/index.js"
compatibility_date = "2025-09-23"
compatibility_flags = ["nodejs_compat", "global_fetch_strictly_public"]
pages_build_output_dir = "dist"
workers_dev = true
send_metrics = false

