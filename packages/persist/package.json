{
  "name": "@basenative/persist",
  "version": "1.0.1",
  "description": "Signal-driven local persistence with TTL, conflict resolution, and a server-rehydrate hook for BaseNative apps",
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./storage": {
      "types": "./types/index.d.ts",
      "default": "./src/storage.js"
    },
    "./ttl": {
      "types": "./types/index.d.ts",
      "default": "./src/ttl.js"
    }
  },
  "types": "./types/index.d.ts",
  "files": [
    "src",
    "types"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DuganLabs/BaseNative.git",
    "directory": "packages/persist"
  },
  "homepage": "https://github.com/DuganLabs/BaseNative#readme",
  "bugs": {
    "url": "https://github.com/DuganLabs/BaseNative/issues"
  },
  "keywords": [
    "basenative",
    "signals",
    "persistence",
    "localstorage",
    "indexeddb",
    "ttl",
    "session-resume"
  ],
  "peerDependencies": {
    "@basenative/runtime": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@basenative/runtime": {
      "optional": true
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}