{
  "name": "@basenative/keyboard",
  "targets": {
    "test": {
      "cache": true,
      "command": "node --test",
      "inputs": [
        "{projectRoot}/src/**/*.js",
        "{projectRoot}/test/**/*.js"
      ],
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "cache": true,
      "command": "pnpm exec eslint src/",
      "inputs": [
        "{projectRoot}/src/**/*.js"
      ],
      "options": {
        "cwd": "{projectRoot}"
      }
    }
  }
}
